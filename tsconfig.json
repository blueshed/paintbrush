{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@blueshed/railroad",
    "types": ["bun"],
    "paths": {
      "@lib/*": ["./lib/*"]
    }
  }
}
